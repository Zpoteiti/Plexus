# Gateway token (matches SERVER's PLEXUS_GATEWAY_TOKEN)
PLEXUS_GATEWAY_TOKEN=plexus-gateway-token

# JWT (same secret as server uses to mint tokens)
JWT_SECRET=plexus-jwt-secret-change-in-prod

# Listening port
GATEWAY_PORT=9090

# Server REST API (gateway proxies here, don't end with /)
PLEXUS_SERVER_API_URL=http://localhost:8080

# Frontend static files (served by gateway)
PLEXUS_FRONTEND_DIR=../plexus-frontend/dist

# Allowed browser origins (comma-separated, no spaces; use * for dev only)
PLEXUS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:9090

# Max browser upload size in bytes (default: 1 GiB). Per-user quota (A-4) is the real bound.
PLEXUS_GATEWAY_UPLOAD_MAX_BYTES=1073741824
