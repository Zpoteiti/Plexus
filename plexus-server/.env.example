# PostgreSQL
DATABASE_URL=postgres://plexus:plexus@localhost:5432/plexus

# Auth
ADMIN_TOKEN=plexus-admin
JWT_SECRET=plexus-jwt-secret-change-in-prod

# Server
SERVER_PORT=8080

# Gateway (server connects TO gateway's WS)
PLEXUS_GATEWAY_WS_URL=ws://localhost:9090/ws/plexus
PLEXUS_GATEWAY_TOKEN=plexus-gateway-token

# Workspace (optional — defaults to ~/.plexus/workspace)
PLEXUS_WORKSPACE_ROOT=/var/lib/plexus/workspace
